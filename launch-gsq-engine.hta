<html>
<head>
<title>Launch Guitar-String-Quartet Engine</title>
<HTA:APPLICATION ID="GSQLauncher"
  APPLICATIONNAME="Launch Guitar-String-Quartet Engine"
  BORDER="thin"
  CAPTION="yes"
  SHOWINTASKBAR="yes"
  SINGLEINSTANCE="no"
  SYSMENU="yes"
  WINDOWSTATE="normal"
  SCROLL="no"
  INNERBORDER="yes"
  MAXIMIZEBUTTON="no"
  MINIMIZEBUTTON="yes"
/>
<style>
  body { font-family: Segoe UI, Tahoma, sans-serif; font-size: 11px; margin: 20px; background: #f5f5f5; }
  h2 { margin: 0 0 4px 0; font-size: 14px; }
  .sub { color: #666; margin-bottom: 16px; font-size: 10px; }
  .btn { display: block; width: 260px; margin: 6px auto; padding: 8px; font-size: 11px; cursor: pointer; }
  .status { margin-top: 16px; padding: 6px; background: #e8e8e8; font-size: 10px; color: #444; }
</style>
</head>
<body>
<center>
  <h2>Guitar-String-Quartet Composition Engine</h2>
  <p class="sub">Menu launcher for the master composition engine</p>
  <div id="buttons">
    <button class="btn" onclick="openFile('prompts\\master-composition-engine.md')">Open Master Engine Prompt</button>
    <button class="btn" onclick="openFile('README.md')">Open Repo README</button>
    <button class="btn" onclick="openFile('compositions\\_index.md')">Open Composition Index</button>
    <button class="btn" onclick="createCurrentRequest()">Create Current Engine Request</button>
    <button class="btn" onclick="openFile('engine-request-templates.txt')">Open Request Templates</button>
    <button class="btn" onclick="openFolder('compositions')">Open Compositions Folder</button>
    <button class="btn" onclick="openFolder('rules')">Open Rules Folder</button>
    <button class="btn" onclick="openFolder('prompts')">Open Prompts Folder</button>
    <button class="btn" onclick="openFolder('references')">Open References Folder</button>
    <button class="btn" onclick="openFolder('scratch')">Open Scratch Folder</button>
    <button class="btn" onclick="window.close()">Exit</button>
  </div>
  <div id="status" class="status">Status: Ready</div>
</center>

<script type="text/vbscript">
' Get repo root from HTA file location
Function GetRepoRoot()
  Dim path, fso
  Set fso = CreateObject("Scripting.FileSystemObject")
  path = Replace(window.location.pathname, "/", "\")
  If Left(path, 1) = "\" Then path = Mid(path, 2)
  GetRepoRoot = fso.GetParentFolderName(path)
End Function

Sub setStatus(msg)
  document.getElementById("status").innerText = "Status: " & msg
End Sub

Sub openFile(relPath)
  Dim fso, shell, fullPath, repoRoot
  Set fso = CreateObject("Scripting.FileSystemObject")
  Set shell = CreateObject("WScript.Shell")
  repoRoot = GetRepoRoot()
  fullPath = fso.BuildPath(repoRoot, relPath)
  If fso.FileExists(fullPath) Then
    shell.Run """" & fullPath & """", 1, False
    setStatus "Opened: " & relPath
  Else
    MsgBox "File not found:" & vbCrLf & relPath, 48, "Error"
    setStatus "Error: " & relPath & " not found"
  End If
End Sub

Sub openFolder(relPath)
  Dim fso, shell, fullPath, repoRoot
  Set fso = CreateObject("Scripting.FileSystemObject")
  Set shell = CreateObject("WScript.Shell")
  repoRoot = GetRepoRoot()
  fullPath = fso.BuildPath(repoRoot, relPath)
  If fso.FolderExists(fullPath) Then
    shell.Run "explorer.exe """ & fullPath & """", 1, False
    setStatus "Opened: " & relPath
  Else
    MsgBox "Folder not found:" & vbCrLf & relPath, 48, "Error"
    setStatus "Error: " & relPath & " not found"
  End If
End Sub

Sub createCurrentRequest()
  Dim fso, shell, repoRoot, templatePath, outputPath, ts, content
  Set fso = CreateObject("Scripting.FileSystemObject")
  Set shell = CreateObject("WScript.Shell")
  repoRoot = GetRepoRoot()
  templatePath = fso.BuildPath(repoRoot, "current-engine-request-template.md")
  outputPath = fso.BuildPath(repoRoot, "current-engine-request.md")
  If Not fso.FileExists(templatePath) Then
    MsgBox "current-engine-request-template.md not found.", 48, "Error"
    setStatus "Error: template not found"
    Exit Sub
  End If
  On Error Resume Next
  Set ts = fso.OpenTextFile(templatePath, 1, False, 0)
  If Err.Number <> 0 Then
    MsgBox "Could not read template: " & Err.Description, 48, "Error"
    setStatus "Error: " & Err.Description
    Exit Sub
  End If
  content = ts.ReadAll
  ts.Close
  Set ts = fso.CreateTextFile(outputPath, True)
  ts.Write content
  ts.Close
  If Err.Number <> 0 Then
    MsgBox "Could not write file: " & Err.Description, 48, "Error"
    setStatus "Error: " & Err.Description
    Exit Sub
  End If
  shell.Run """" & outputPath & """", 1, False
  setStatus "Created and opened: current-engine-request.md"
  MsgBox "current-engine-request.md created and opened.", 64, "Success"
End Sub
</script>
</body>
</html>
